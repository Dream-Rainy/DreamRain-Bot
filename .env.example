# Copy this file to .env or .env.prod and fill in real values on your host.
# Never commit real secrets.

# NoneBot
HOST=0.0.0.0
PORT=8080
COMMAND_START=["/"]
COMMAND_SEP=.
NICKNAME=["DreamRain"]
LOG_LEVEL=INFO
SUPERUSERS=["100000000"]

# OneBot / NapCat
ONEBOT_ACCESS_TOKEN=change-me
NAPCAT_PORT=6099
NAPCAT_CONFIG_DIR=./runtime/napcat/config
QQ_CONFIG_DIR=./runtime/qq-config

# Docker / runtime paths
TZ=Asia/Shanghai
UID=1000
GID=1000
APP_DATA_DIR=./runtime/data
APP_LOG_DIR=./runtime/logs
POSTGRES_DATA_DIR=./runtime/postgres_data
PLAYWRIGHT_PORT=3000
HTMLRENDER_CONNECT=ws://playwright:3000
HTTP_PROXY=
HTTPS_PROXY=
PRICONNE_CREDENTIAL_KEY_FILE=/run/secrets/priconne_credential_key
PRICONNE_CREDENTIAL_KEY_SOURCE=./secrets/priconne_credential_key

# Docker image
BOT_IMAGE=dreamrain-bot:latest

# Database
POSTGRES_USER=dreamrain
POSTGRES_PASSWORD=change-me
POSTGRES_DB=dreamrain_bot
POSTGRES_PORT=5432
db_engine=postgres
db_credentials={"host":"postgres","port":5432,"user":"dreamrain","password":"change-me","database":"dreamrain_bot"}
SQLALCHEMY_DATABASE_URL=postgresql+asyncpg://dreamrain:change-me@postgres:5432/dreamrain_bot

# LXNS
lxns_api_key=change-me
lxns_client_id=change-me
lxns_client_secret=change-me
lxns_base_url=https://maimai.lxns.net
lxns_oauth_redirect_uri=
lxns_oauth_scope=
dxrating_api_key=
ingame_data_base_dir=data/chiffon_bot/ingame_data

# Localstore
LOCALSTORE_DATA_DIR=data
LOCALSTORE_PLUGIN_DATA_DIR=data

# permission_admin
control_groups=[]

# Repeater
repeater_group=[]
repeater_min_message_length=3
repeater_min_message_times=3
repeater_blacklist=[]

# Bilibili analysis
analysis_group_blacklist=[]

# Fortune
FORTUNE_PATH=
ASOUL_FLAG=false
HOLOLIVE_FLAG=false
LIQINGGE_FLAG=false

# Picstatus
PS_ONLY_SU=false
PS_BG_PROVIDER=
PS_COMMAND=status
PS_IGNORE_PARTS=[]
PS_IGNORE_DISK_IOS=false
PS_TEST_SITES=[]

# PCRJJC
PCRJJC_GROUP=
PCRJJC_ACCOUNTS=[]
notice_cd_min=30

# priconne
priconne_captcha_auto=true
priconne_captcha_admin_group=0
priconne_captcha_timeout=120

# autopcr
autopcr_prefix="#"
autopcr_api_base_url=https://autopcr.example.com/daily/api/
autopcr_public_base_url=https://autopcr.example.com/daily/
autopcr_bot_token=
autopcr_request_timeout=300
autopcr_startup_healthcheck=false

# Optional adapters
ENABLE_CONSOLE_DEBUG=false
ENABLE_TELEGRAM=false
ENABLE_DISCORD=false
ENABLE_KAIHEILA=false
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
KAIHEILA_BOT_TOKEN=
